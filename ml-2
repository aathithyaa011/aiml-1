# Basic linear regression from scratch using pure Python.

x_values = [1, 2, 3, 4, 5]
y_values = [2, 4, 5, 4, 5]


def mean(values):
    return sum(values) / len(values)


def train_linear_regression(x_data, y_data):
    x_mean = mean(x_data)
    y_mean = mean(y_data)

    numerator = 0
    denominator = 0

    for x, y in zip(x_data, y_data):
        numerator += (x - x_mean) * (y - y_mean)
        denominator += (x - x_mean) ** 2

    slope = numerator / denominator
    intercept = y_mean - slope * x_mean
    return slope, intercept


def predict(x, slope, intercept):
    return slope * x + intercept


slope, intercept = train_linear_regression(x_values, y_values)
predicted_value = predict(6, slope, intercept)

print("Slope:", round(slope, 2))
print("Intercept:", round(intercept, 2))
print("Prediction for x = 6:", round(predicted_value, 2))
